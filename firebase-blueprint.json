{
  "entities": {
    "Quiz": {
      "title": "Quiz Metadata",
      "description": "Stores information about a quiz created by a teacher.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the quiz." },
        "timeLimit": { "type": "number", "description": "Time limit in minutes." },
        "questionCount": { "type": "number", "description": "Total number of questions." },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "Whether the quiz is active." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "authorId": { "type": "string", "description": "UID of the teacher who created the quiz." }
      },
      "required": ["title", "timeLimit", "status", "authorId"]
    },
    "Question": {
      "title": "Quiz Question",
      "description": "A single multiple-choice question within a quiz.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The question text." },
        "options": {
          "type": "object",
          "properties": {
            "A": { "type": "string" },
            "B": { "type": "string" },
            "C": { "type": "string" },
            "D": { "type": "string" }
          },
          "required": ["A", "B", "C", "D"]
        },
        "correctAnswer": { "type": "string", "enum": ["A", "B", "C", "D"], "description": "The correct option key." }
      },
      "required": ["text", "options", "correctAnswer"]
    },
    "Result": {
      "title": "Student Result",
      "description": "Stores a student's performance on a quiz.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string", "description": "Full name of the student." },
        "studentId": { "type": "string", "description": "University student ID." },
        "score": { "type": "number", "description": "Total score achieved." },
        "answers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of answers provided by the student."
        },
        "submittedAt": { "type": "string", "format": "date-time", "description": "Submission timestamp." }
      },
      "required": ["studentName", "studentId", "score", "submittedAt"]
    }
  },
  "firestore": {
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of quizzes."
    },
    "/quizzes/{quizId}/questions/{questionId}": {
      "schema": "Question",
      "description": "Sub-collection of questions for a quiz."
    },
    "/quizzes/{quizId}/results/{resultId}": {
      "schema": "Result",
      "description": "Sub-collection of student results for a quiz."
    },
    "/users/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "teacher"] }
        }
      },
      "description": "Teacher profiles."
    }
  }
}
